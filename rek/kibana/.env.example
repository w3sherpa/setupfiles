KIBANA_VERSION=9.4.0
KIBANA_CONTAINER_NAME=sherpaticket_kibana

KIBANA_PORT=5601

# Elasticsearch connection inside Docker network
ELASTICSEARCH_HOSTS=http://sherpaticket_elasticsearch:9200

# Kibana should NOT use the "elastic" superuser internally.
# Use the built-in kibana_system user.
KIBANA_ELASTICSEARCH_USERNAME=kibana_system
KIBANA_ELASTICSEARCH_PASSWORD=_CHANGE_ME_TO_SECURE_PWD_